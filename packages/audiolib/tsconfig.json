{
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,

    "allowJs": true,
    "checkJs": false,

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"], // ? , "WebWorker"], ?

    "declarationMap": true, // ?
    "useDefineForClassFields": true,

    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,

    "types": ["@types/audioworklet"],

    "skipLibCheck": true,
    "declaration": true,
    "noEmit": false,

    "declarationDir": "./dist",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/test/*", "src/**/*.test*"]
}
